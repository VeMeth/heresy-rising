# Copy to .env and set real values before going public.
# This file is safe to commit; .env is gitignored and must never be committed.

# Strong admin password for the /admin control panel.
# REQUIRED in production: if unset or left as the shipped default, admin
# endpoints are automatically disabled (fail-closed) and the server logs a
# security warning. Generate one, e.g.: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_PASSWORD=change-me-to-a-long-random-secret

# Port the game API/WebSocket server listens on (inside the container).
SERVER_PORT=4100

# Bind the server port only to loopback on the host so it is not directly
# exposed to the internet. The public-facing nginx client container proxies to it.
SERVER_HOST_BIND=127.0.0.1

# Public-facing client port (the nginx container maps this to 80 internally).
CLIENT_PORT=8281

# Comma-separated list of browser origins allowed to use the API/sockets.
# List every public URL the site will be served from. No wildcards in production.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8281

# The server always runs behind the nginx reverse proxy in this stack, so we
# trust X-Forwarded-* headers. This makes rate limiting and per-clientLimits
# key on the real client IP instead of the proxy's IP. Keep this true.
TRUST_PROXY=true

# ── Heresy Bots (AI operatives) ───────────────────────────────────────────
# Three separate secrets (per the locked v1.1.0 bot spec):
#   BOT_API_KEY        — manager ↔ engine HTTP auth (reserve/despawn seats).
#   ADMIN_API_KEY      — gate the admin panel path (proxied from heresy-server).
#   SIM_BYPASS_TOKEN   — direct path for the sim/test harness.
# All three are REQUIRED in production. Generate strong random values for each:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
BOT_API_KEY=change-me-to-a-long-random-secret
ADMIN_API_KEY=change-me-to-a-long-random-secret
SIM_BYPASS_TOKEN=change-me-to-a-long-random-secret

# MiniMax LLM credentials. Required before any bot will actually act — without
# a key, bots spawn and join but pass every turn (silent observers).
MiniMax_API_KEY=
MiniMax_MODEL=MiniMax-M3
MiniMax_BASE_URL=https://api.minimax.io/v1

# Manager-side tunables. Defaults match the spec; override per deployment.
MAX_BOT_SESSIONS=12            # global cap (one per seat at max player count)
MAX_BOTS_PER_GAME=4            # hard cap per Conclave
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=0.7
MAX_TOKENS=512
MAX_TOKENS_PER_GAME=50000
BOT_ACTION_DELAY_MS=10000      # fixed pacing delay after a prompt (Q-BOT-1)
CHAT_DEBOUNCE_MS=2000          # cooldown between a bot's chat replies
LANGCHAIN_TRACING=false